    "import sys\n",
    "sys.path.append('..')\n",
    "from backend.utils.nasa_fetcher import fetch_weather\n",
    "import pandas as pd\n",
    "\n",
    "province_coords = {\n",
    "    \"Punjab\":      (31.5204, 74.3587),\n",
    "    \"Sindh\":       (24.8607, 67.0011),\n",
    "    \"KPK\":         (34.0151, 71.5249),\n",
    "    \"Balochistan\": (30.1798, 66.9750),\n",
    "    \"ICT\":         (33.6844, 73.0479),\n",
    "    \"AJK\":         (33.9260, 73.7840),\n",
    "    \"GB\":          (35.8884, 74.4584),\n",
    "}\n",
    "\n",
    "weather_frames = []\n",
    "for region, (lat, lon) in province_coords.items():\n",
    "    print(f\"Fetching {region}...\")\n",
    "    df_wx = fetch_weather(lat, lon, \"20160101\", \"20201231\")\n",
    "    df_wx[\"region\"] = region\n",
    "    weather_frames.append(df_wx)\n",
    "\n",
    "df_weather = pd.concat(weather_frames, ignore_index=True)\n",
    "\n",
    "# merge with weekly province cases\n",
    "df_weekly = pd.read_csv(\"data/raw/pakistan_province_weekly.csv\")\n",
    "df_merged = pd.merge(\n",
    "    df_weekly, df_weather,\n",
    "    on=[\"region\", \"year\", \"epi_week\"],\n",
    "    how=\"inner\"\n",
    ")\n",
    "\n",
    "print(f\"Merged shape: {df_merged.shape}\")\n",
    "df_merged.to_csv(\"data/processed/pakistan_province_weekly_merged.csv\", index=False)\n",
    "print(\"Saved.\")"
   ]
