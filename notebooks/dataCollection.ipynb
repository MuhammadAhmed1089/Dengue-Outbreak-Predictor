    "import pandas as pd\n",
    "\n",
    "\n",
    "def convertToCSV(file, output_file=None, **kwargs):\n",
    "    df = pd.read_excel(file, **kwargs)\n",
    "    \n",
    "    if output_file is None:\n",
    "        output_file = file.rsplit('.', 1)[0] + '.csv'\n",
    "    \n",
    "    df.to_csv(\n",
    "        output_file,\n",
    "        index=False,\n",
    "        encoding='utf-8-sig'\n",
    "    )\n",
    "    \n",
    "    print(f\"Converted: {file} → {output_file}\")\n",
    "    return output_file\n",
    "\n",
    "\n"
   ]
